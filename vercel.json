{
    "version": 2,
    "regions": ["hnd1"],
    "builds": [
        {
            "src": "public/index.php",
            "use": "@vercel/static-build"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "public/index.php"
        }
    ],
    "env": {
        "APP_NAME": "Laravel Vercel",
        "APP_ENV": "production",
        "APP_KEY": "base64:bDtD5OD8SAunaIW8IjIYF80L0h7IAujePbHWTpr5dJ0=",
        "APP_DEBUG": "false",
        "APP_URL": "https://post-card-be.vercel.app/",
        "LOG_CHANNEL": "stderr",
        "CACHE_DRIVER": "array",
        "SESSION_DRIVER": "cookie",
        "VIEW_COMPILED_PATH": "/tmp",
        "APP_STORAGE": "/tmp"
    }
}